pkgname=python-banal
_pkgname=banal
pkgver=1.1.2
pkgrel=1
pkgdesc='Commons of banal micro-functions for Python.'
arch=('any')
url='https://pypi.org/project/banal/#files'
license=('MIT')
depends=('python' 'python-six')
makedepends=('python-setuptools')
#source=("https://files.pythonhosted.org/packages/source/${_pkgname::1}/$_pkgname/$_pkgname-$pkgver.tar.gz")
source=("https://github.com/pudo/banal/archive/refs/tags/$pkgver.tar.gz")
sha512sums=('6eb4c7cf00cde72048278b65c9f627629518e47f12535a120c88fccf1362b2189b4b13cb897ba3731cfe4b29e8ef8b8131e38f0505cecfb506cedd2217c26c9c')

build() {
  cd "$_pkgname-$pkgver"

  python setup.py build
}

package() {
  cd "$_pkgname-$pkgver"

  python setup.py install --root="$pkgdir" --prefix=/usr -O1 --skip-build
}

