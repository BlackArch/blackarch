pkgbase=python-libregf-python
pkgname=('python2-libregf-python' 'python-libregf-python')
_pkgname=libregf-python
pkgver=20260526
pkgrel=1
pkgdesc='Python bindings module for libregf.'
arch=('x86_64' 'aarch64')
url='https://pypi.python.org/pypi/libregf-python/'
license=('LGPL3')
makedepends=('python2-setuptools' 'python-setuptools')
source=("https://files.pythonhosted.org/packages/source/${_pkgname::1}/$_pkgname/$_pkgname-$pkgver.tar.gz")
sha512sums=('b3bddd07f6d21b6257cfd9c647c6685b15cd1769da11ac4246e2ce37685c19ac2ae435f863712347a160ce187a96883923cb3c941414cc5d3c1541ce1146fbad')

package_python2-libregf-python() {
  depends=('python2')

  cd "libregf-$pkgver"

  python2 setup.py install --prefix=/usr --root="$pkgdir" --optimize=1
}

package_python-libregf-python() {
  depends=('python')

  cd "libregf-$pkgver"

  python setup.py install --prefix=/usr --root="$pkgdir" --optimize=1
}

