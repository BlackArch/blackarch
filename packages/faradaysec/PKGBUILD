options=('!strip')
license=('GPL-3.0-or-later')
source=("$pkgname::https://github.com/infobyte/$_pkgname/archive/refs/tags/v$pkgver.tar.gz")
sha512sums=('SKIP')

prepare() {
  cd "$_pkgname-$pkgver"

  sed -i 's/setuptools>=61,<82/setuptools>=61,<83/g' pyproject.toml
}

build() {
  cd "$_pkgname-$pkgver"

  python -m build --wheel --no-isolation
}

package() {
  cd "$_pkgname-$pkgver"

  python -m installer --destdir="$pkgdir" dist/*.whl
}

