pkgname=python-azure-mgmt-keyvault
_pkgname=azure-mgmt-keyvault
pkgver=14.0.1
pkgrel=1
pkgdesc='Microsoft Azure Key Vault Management Client Library for Python.'
arch=('any')
url='https://pypi.org/project/azure-mgmt-keyvault/#files'
license=('MIT')
depends=('python')
makedepends=('python-setuptools')
source=("https://files.pythonhosted.org/packages/source/${_pkgname::1}/$_pkgname/$_pkgname-$pkgver.zip")
sha512sums=('781319a56e8dce1918a450ba7636882e86f2a9dff2c0d0d8721973d65de8d54eed892a0202b31c82e3f4be1ece2066f6fa8c71093d1ee8db85f30126b768bd6b')

build() {
  cd "$_pkgname-$pkgver"

  python setup.py build
}

package() {
  cd "$_pkgname-$pkgver"

  python setup.py install --prefix=/usr --root="$pkgdir" --optimize=1 \
    --skip-build
}

