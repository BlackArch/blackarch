pkgname=python-scruffington
_pkgname=scruffington
pkgver=0.3.10
pkgrel=1
pkgdesc='The janitor.'
url='https://pypi.org/project/scruffington/#files'
arch=('any')
license=('MIT')
depends=('python')
makedepends=('python-setuptools')
source=("https://files.pythonhosted.org/packages/source/${_pkgname::1}/$_pkgname/$_pkgname-$pkgver.tar.gz")
sha512sums=('abc451ba35ab8d1098c8e8fa3b77181e50b14dbbacf86dcca0972ccde77ab8950042e994ef94dde6cec7f0f517c49737a87632bd3467937fb86ec8149ef1d297')

build() {
  cd "$_pkgname-$pkgver"

  python setup.py build
}

package() {
  cd "$_pkgname-$pkgver"

  python setup.py install --prefix=/usr --root="$pkgdir" --optimize=1 \
    --skip-build
}

