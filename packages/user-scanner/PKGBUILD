pkgname=user-scanner
pkgver=1.3.6
pkgrel=1
pkgdesc='OSINT tool that analyzes username and email presence across multiple platforms, intended for security research, investigations, legitimate analysis.'
arch=('any')
groups=('blackarch' 'blackarch-social' 'blackarch-recon' 'blackarch-scanner')
url='https://github.com/kaifcodec/user-scanner'
license=('MIT')
depends=('python' 'python-httpx' 'python-socksio' 'python-colorama')
makedepends=('python-build' 'python-installer' 'python-setuptools'
             'python-wheel' 'python-flit-core')
source=("$url/archive/refs/tags/v$pkgver.tar.gz")
sha512sums=('0162bf4c32d954275db579428fad6cf29dce6b9ce512c35b602ae3b573b592109b6a93efecded1f5582571036ed59b665f266fdd3657429a98ed9fe1a9d84bf7')

build() {
  cd "$pkgname-$pkgver"

  python -m build --wheel --no-isolation
}

package() {
  cd "$pkgname-$pkgver"

  python -m installer --destdir="$pkgdir" dist/*.whl
}

