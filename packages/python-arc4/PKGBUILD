pkgname=python-arc4
_pkgname=arc4
pkgver=0.5.0
pkgrel=1
pkgdesc='A small and insanely fast ARCFOUR (RC4) cipher implementation of Python.'
arch=('x86_64' 'aarch64')
url='https://pypi.org/project/arc4/#files'
license=('MIT')
depends=('python')
makedepends=('python-setuptools')
source=("https://files.pythonhosted.org/packages/source/${_pkgname::1}/$_pkgname/$_pkgname-$pkgver.tar.gz")
sha512sums=('606dd99aee8d246e17ffe1eb48c5a20e2be9d7326f8ebd98e15e7cf00e634539dc1d53429880b4723f5b69c9b6e2097a178da3d95620519577340115b74d5c21')

build() {
  cd "$_pkgname-$pkgver"

  python setup.py build
}

package() {
  cd "$_pkgname-$pkgver"

  python setup.py install --root="$pkgdir" --prefix=/usr -O1 --skip-build
}

