pkgname=python-ollama
_pkgname=${pkgname#python-}
pkgver=0.6.2
pkgrel=1
pkgdesc='The official Python client for Ollama.'
arch=('any')
url='https://pypi.org/project/ollama/#files'
license=('MIT')
depends=('python' 'ollama' 'python-httpx' 'python-typing_extensions'
         'python-pydantic' 'python-anyio')
makedepends=('python-build' 'python-installer' 'python-setuptools'
             'python-wheel' 'python-hatchling' 'python-hatch-vcs')
options=(!emptydirs)
source=("https://files.pythonhosted.org/packages/source/${_pkgname::1}/$_pkgname/$_pkgname-$pkgver.tar.gz")
sha512sums=('dbac2015316ac4b8d706e875741a7c01786c3bc2fc039f7c47920762b7ad3834f6233d4a06cd84d8d1234f268c69e764d1af0b738fb3c8b9e6c51a85a25b4f70')

build() {
  cd "$_pkgname-$pkgver"

  python -m build --wheel --no-isolation
}

package() {
  cd "$_pkgname-$pkgver"

  python -m installer --destdir="$pkgdir" dist/*.whl
}

