pkgname=python-dataset
_pkgname=dataset
pkgver=2.0.0
pkgrel=1
pkgdesc='Toolkit for Python-based data processing.'
arch=('any')
url='https://pypi.org/project/dataset/'
license=('MIT')
depends=('python' 'python-six' 'python-sqlalchemy' 'python-alembic'
         'python-normality')
makedepends=('python-setuptools')
source=("https://files.pythonhosted.org/packages/source/${_pkgname::1}/$_pkgname/$_pkgname-$pkgver.tar.gz")
sha512sums=('267a98cad02b88205179165bf70d9aeca62dbe2879eb3c821feea5222ad07cd5bac18d22e54116bf9ad407d3582fd5991e2ac69876039bfc9daf0d8825c65652')

build() {
  cd "$_pkgname-$pkgver"

  python setup.py build
}

package() {
  cd "$_pkgname-$pkgver"

  python setup.py install --root="$pkgdir" --prefix=/usr -O1 --skip-build
}

