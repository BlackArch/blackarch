pkgname=python-dfdatetime
_pkgname=dfdatetime
pkgver=20260411
pkgrel=1
pkgdesc='Digital Forensics Date and Time.'
arch=('any')
url='https://pypi.org/project/dfdatetime/'
license=('Apache')
depends=('python')
makedepends=('python-setuptools')
source=("https://files.pythonhosted.org/packages/source/${_pkgname::1}/$_pkgname/$_pkgname-$pkgver.tar.gz")
sha512sums=('4d825994eea5d6341becf7b6ed7ee7b075ba07bd523590c38956689e03bf3e9863a82b1dff23417c89e2ecf2be4b6c92970802e0c9f8a052b5bb875c63368cf7')

build() {
  cd "$_pkgname-$pkgver"

  python setup.py build
}

package() {
  cd "$_pkgname-$pkgver"

  python setup.py install --root="$pkgdir" --prefix=/usr -O1 --skip-build
}

