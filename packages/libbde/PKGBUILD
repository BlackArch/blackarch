# See COPYING for license details.

pkgname=libbde
pkgver=20240502.r15.gda0c50b
pkgrel=1
epoch=1
pkgdesc='A library to access the BitLocker Drive Encryption (BDE) format.'
groups=('blackarch' 'blackarch-crypto')
arch=('x86_64' 'aarch64')
url='https://github.com/libyal/libbde'
license=('LGPL-3.0-or-later')
provides=('libbde')
depends=('python' 'python2')
makedepends=('git' 'autoconf' 'automake' 'libtool' 'gettext' 'pkg-config'
             'bison' 'flex')
source=("git+https://github.com/libyal/$pkgname.git")
sha512sums=('SKIP')

pkgver() {
  cd $pkgname

  ( set -o pipefail
    git describe --long --tags --abbrev=7 2>/dev/null |
      sed 's/\([^-]*-g\)/r\1/;s/-/./g' ||
    printf "%s.%s" "$(git rev-list --count HEAD)" \
      "$(git rev-parse --short=7 HEAD)"
  )
}

build() {
  cd $pkgname

  ./synclibs.sh
  ./autogen.sh
  ./configure \
    --prefix=/usr \
    --sysconfdir=/etc \
    --enable-python2 \
    --enable-python

  make
}

package() {
  cd $pkgname

  make DESTDIR="$pkgdir" install
}

