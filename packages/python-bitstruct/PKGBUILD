pkgname=python-bitstruct
_pkgname=bitstruct
pkgver=8.22.1
pkgrel=1
pkgdesc='This module performs conversions between Python values and C bit field structs represented as Python byte strings.'
arch=('x86_64' 'aarch64')
url='https://pypi.org/project/bitstruct/#files'
license=('custom:unknown')
makedepends=('python-setuptools')
depends=('python')
source=("https://files.pythonhosted.org/packages/source/${_pkgname::1}/$_pkgname/$_pkgname-$pkgver.tar.gz")
sha512sums=('2795eb8d319a17dec0169bc67f332a08b5b2863c3f40351fb31c4cf876fe3915a72594bff3506689549c9119873e11ee3c590b0cb293758a102891101d0eebcb')

build() {
  cd "$_pkgname-$pkgver"

  python setup.py build
}

package() {
  cd "$_pkgname-$pkgver"

  python setup.py install --root="$pkgdir" --prefix=/usr -O1 --skip-build

  install -Dm 644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}

