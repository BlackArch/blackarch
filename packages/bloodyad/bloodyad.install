post_install() {
  set -e
  cd /usr/share/bloodyad
  python -m venv venv
  source venv/bin/activate &&
    pip install --isolated --root=/usr/share/bloodyad --prefix=venv .
}

post_upgrade() {
  set -e
  cd /usr/share/bloodyad
  source venv/bin/activate &&
    pip install --isolated --root=/usr/share/bloodyad --prefix=venv . -U
  # post_install "$@"
}

post_remove() {
  # /usr/share/bloodyad/venv
  rm -rf /usr/share/bloodyad
}

