pkgname=libowfat
pkgver=0.34
pkgrel=1
pkgdesc='GPL reimplementation of libdjb.'
arch=('x86_64' 'aarch64')
url='http://www.fefe.de/libowfat/'
depends=('dietlibc')
license=('GPL')
options=('staticlibs')
source=("http://www.fefe.de/libowfat/libowfat-$pkgver.tar.xz"
        "gcc15.patch")
sha512sums=('5be668f78d86c8591c8f2b8067f8ce41a38891b977ab239ee64602c37232aa85c396e07fedd378be12c6730080ca2ada08964cebd6e844191fce0c8cff57bb47'
            'd881cbcd24942054b6de13a25ecd9177bc6fb4cbe27e4c42a54f8ae2dc77e843ae9767f8723605e18d3a87ed4f9eb74530e6720ee2c9aa7fcce938c43ad9c609')
install="$pkgname.install"

build() {
  cd "$pkgname-$pkgver"

  patch -p1 < ../../gcc15.patch

  DIET= make
}

package() {
  cd "$pkgname-$pkgver"

  DIET= make prefix="$pkgdir/usr/" LIBDIR="$pkgdir/usr/lib" \
    MAN3DIR="$pkgdir/usr/share/man/man3" install

  cd "$pkgdir/usr/share/man/man3"

  mv buffer.3 buffer-libowfat.3
}

