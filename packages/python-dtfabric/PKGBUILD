pkgname=python-dtfabric
_pkgname=dtfabric
pkgver=20260506
pkgrel=1
pkgdesc='Tooling for data type and structure management.'
arch=('any')
url='https://pypi.org/project/dtfabric/#files'
license=('Apache')
depends=('python' 'python-pyaml')
makedepends=('python-setuptools')
source=("https://files.pythonhosted.org/packages/source/${_pkgname::1}/$_pkgname/$_pkgname-$pkgver.tar.gz")
sha512sums=('637c20a6ba37ed85a49eb9d2d9c4e9fa09cd381ea9899466844312128c3e5a73d85ca6cbec1c8011f8437c18e5e16340bcca5b0471293758c5f570fa7464a818')

build() {
  cd "$_pkgname-$pkgver"

  python setup.py build
}

package() {
  cd "$_pkgname-$pkgver"

  python setup.py install --root="$pkgdir" --prefix=/usr -O1 --skip-build
}

