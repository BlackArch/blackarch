pkgname=python-azure-mgmt-network
_pkgname=azure-mgmt-network
pkgver=30.2.0
pkgrel=1
pkgdesc='Microsoft Azure Network Management Client Library for Python.'
arch=('any')
url='https://pypi.org/project/azure-mgmt-network/#files'
license=('MIT')
depends=('python')
makedepends=('python-setuptools')
source=("https://files.pythonhosted.org/packages/source/${_pkgname::1}/$_pkgname/$_pkgname-$pkgver.zip")
sha512sums=('aa556df1bf44d8fb9dbe382a71db9587c4b1521e194863717d6cc8af30ec95ecfd1614c0423f7417249cfdb0fc5435173a6b7fa2477eabb97b5adfbff9f6d8b9')

build() {
  cd "$_pkgname-$pkgver"

  python setup.py build
}

package() {
  cd "$_pkgname-$pkgver"

  python setup.py install --prefix=/usr --root="$pkgdir" -O1 --skip-build
}

