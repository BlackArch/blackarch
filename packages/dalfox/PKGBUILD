# See COPYING for license details.

pkgname=dalfox
pkgver=v3.1.2.r11.ge9f8fd2
pkgrel=1
epoch=1
pkgdesc='Powerful open-source XSS scanner and utility focused on automation.'
arch=('x86_64' 'aarch64')
groups=('blackarch' 'blackarch-webapp' 'blackarch-fuzzer' 'blackarch-scanner')
url='https://github.com/hahwul/dalfox'
license=('MIT')
depends=('glibc')
makedepends=('git' 'cargo')
source=("git+https://github.com/hahwul/$pkgname.git")
sha512sums=('SKIP')

pkgver() {
  cd $pkgname

  ( set -o pipefail
    git describe --long --tags --abbrev=7 2>/dev/null |
      sed 's/\([^-]*-g\)/r\1/;s/-/./g' ||
    printf "%s.%s" "$(git rev-list --count HEAD)" \
      "$(git rev-parse --short=7 HEAD)"
  )
}

build() {
  CFLAGS+=' -ffat-lto-objects'
  cd $pkgname

  cargo build --release --locked

}

package() {
  cd $pkgname

  install -Dm 755 "target/release/$pkgname" "$pkgdir/usr/bin/$pkgname"
  install -Dm 644 README.md -t "$pkgdir/usr/share/doc/$pkgname"

  cp -a docs/ AGENTS.md CHANGELOG.md "$pkgdir/usr/share/doc/$pkgname/"

  install -Dm 644 LICENSE.txt "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}

