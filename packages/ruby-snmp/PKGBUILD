pkgname=ruby-snmp
_gemname=snmp
pkgver=1.3.4
pkgrel=1
pkgdesc='A Ruby implementation of SNMP (the Simple Network Management Protocol).'
arch=('any')
license=('MIT')
makedepends=('ruby')
url='https://rubygems.org/gems/snmp'
source=("https://rubygems.org/gems/$_gemname-$pkgver.gem")
sha512sums=('e159ba07dd078fa851bc948f5313cd2625edf6a196d4feee5ec228f9af5fc87226fabd382cca9ae95023b69a5c4ab794e104f2b56ab414b708235b5a80e87602')
noextract=("$_gemname-$pkgver.gem")

package() {
  _gemdir=$(ruby -e 'puts Gem.default_dir')

  if [[ $CARCH == arm* ]] ; then
    gem install --no-user-install --ignore-dependencies --no-rdoc --no-ri \
      -i "$pkgdir$_gemdir" "$_gemname-$pkgver.gem"
  else
    gem install --no-user-install --ignore-dependencies -i "$pkgdir$_gemdir" \
      -n "$pkgdir/usr/bin" "$_gemname-$pkgver.gem"
  fi
}

