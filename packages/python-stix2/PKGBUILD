pkgname=python-stix2
_pkgname=cti-python-stix2
pkgver=3.0.2
pkgrel=1
pkgdesc='Produce and consume STIX 2 JSON content.'
url='https://github.com/oasis-open/cti-python-stix2'
license=('BSD-3-Clause')
arch=('any')
depends=('python' 'python-dateutil' 'python-pytz' 'python-requests'
         'python-simplejson' 'python-six' 'python-stix2-patterns')
makedepends=('python-build' 'python-installer' 'python-setuptools'
             'python-wheel')
options=(!emptydirs)
source=("https://github.com/oasis-open/cti-python-stix2/archive/refs/tags/v$pkgver.tar.gz")
sha512sums=('ede4253eefcf5acfc8ff8029f9bb271959f2aab1041d24b09510d143a9a0a74d70be1fd16f6936ae6872ee004b6060791e0262950ea8a77afacdf6360434df8d')

build() {
  cd "$_pkgname-$pkgver"

  python -m build --wheel --no-isolation
}

package() {
  cd "$_pkgname-$pkgver"

  python -m installer --destdir="$pkgdir" dist/*.whl
}

