pkgname=python-zeo
_pkgname=${pkgname#python-}
pkgver=6.2
pkgrel=1
pkgdesc='A client-server storage for ZODB for sharing a single storage among many clients.'
arch=('any')
url='https://pypi.org/project/ZEO/'
license=('custom:unknown')
depends=('python' 'python-zdaemon' 'python-zodb' 'python-six' 'python-zconfig'
         'python-transaction' 'python-persistent' 'python-zc.lockfile'
         'python-zope-interface')
makedepends=('python-build' 'python-installer' 'python-setuptools'
             'python-wheel')
options=(!emptydirs)
source=("https://files.pythonhosted.org/packages/source/${_pkgname::1}/$_pkgname/$_pkgname-$pkgver.tar.gz")
sha512sums=('1b0f5b7bbd2572064afa789e2a2cf75422e68b1892028a6aa869f6a0c7cc533a109c70477675b1d4b2c1e5b0e91f40e7a2827e2119ea179c0518b5bf9dc3f29e')

prepare() {
  cd "$_pkgname-$pkgver"

  sed -i 's|setuptools == 75.8.2|setuptools|g' pyproject.toml
}

build() {
  cd "$_pkgname-$pkgver"

  python -m build --wheel --no-isolation
}

package() {
  cd "$_pkgname-$pkgver"

  python -m installer --destdir="$pkgdir" dist/*.whl
}

