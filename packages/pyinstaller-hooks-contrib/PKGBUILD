pkgname=pyinstaller-hooks-contrib
_pkgname=pyinstaller_hooks_contrib
pkgver=2026.6
pkgrel=1
pkgdesc='PyInstaller community hooks.'
arch=('any')
groups=('blackarch' 'blackarch-misc')
url='https://github.com/pyinstaller/pyinstaller-hooks-contrib'
license=('custom:mixed')
depends=('python')
makedepends=('python-build' 'python-installer' 'python-wheel' 'python-setuptools')
source=("https://files.pythonhosted.org/packages/source/${_pkgname::1}/$_pkgname/$_pkgname-$pkgver.tar.gz")
sha512sums=('c5a379b85ac55cd0e087b9f9505e6a3fcd3cebdaddd2e2fe05c850961300d1a93fd0af779d8425eac633f555aa624e654d4cb6eb898dc873b90de636c4684706')

build() {
  cd "$_pkgname-$pkgver"

  python -m build --wheel --no-isolation
}

package() {
  cd "$_pkgname-$pkgver"

  python -m installer --destdir="$pkgdir" dist/*.whl
}

