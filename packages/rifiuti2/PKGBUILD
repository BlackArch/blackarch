# See COPYING for license details.

pkgname=rifiuti2
pkgver=0.8.2
pkgrel=1
epoch=1
groups=('blackarch' 'blackarch-forensic' 'blackarch-recon')
pkgdesc='A rewrite of rifiuti, a great tool from Foundstone folks for analyzing Windows Recycle Bin INFO2 file.'
url='https://github.com/abelcheung/rifiuti2'
arch=('x86_64' 'aarch64')
license=('custom:BSD')
conflicts=('rifiuti')
depends=('glib2')
makedepends=('git' 'cmake')
source=("https://github.com/abelcheung/$pkgname/releases/download/$pkgver/$pkgname-$pkgver.tar.xz")
sha512sums=('c378523e5929eba794b004ee306c22a2b99625bfdfae1b1603cd82bd427aeb1063fc9a0d16535af8d0df9abdbbd7dd26a232e7d25300fe2e24cc8160cb20b3f3')

build() {
  cd "$pkgname-$pkgver"

  cmake -DCMAKE_INSTALL_PREFIX=/usr .

  make
}

package() {
  cd "$pkgname-$pkgver"

  make DESTDIR="$pkgdir" install

  install -Dm 644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
  install -Dm 644 -t "$pkgdir/usr/share/doc/$pkgname/" NEWS.md docs/*
}

