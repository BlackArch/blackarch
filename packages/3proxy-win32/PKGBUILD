pkgname=3proxy-win32
_pkgname="${pkgname%-win32}"
pkgver=0.9.6.1
pkgrel=1
groups=('blackarch' 'blackarch-windows' 'blackarch-proxy')
pkgdesc='Tiny free proxy server.'
url='http://3proxy.ru/'
license=('Apache-2.0' 'GPL-2.0-or-later')
arch=('any')
source=("https://github.com/3proxy/3proxy/releases/download/0.9.6/$_pkgname-$pkgver.zip")
sha512sums=('55eda2e79dcf2886cd95d38210b2d78be762c027db4e32291813f28662acbb5bafa94939e29fd0919ffcb419f5b8f5b8f3ab46e80dd7175b71cf701507c70a53')

package() {
  install -dm 755 "$pkgdir/usr/share/windows/$pkgname"

  rm "$_pkgname-$pkgver.zip"

  cp -a * "$pkgdir/usr/share/windows/$pkgname"
}

