pkgbase=python-wakeonlan
pkgname=('python2-wakeonlan' 'python-wakeonlan')
_pkgname=wakeonlan
pkgver=3.3.0
pkgrel=1
pkgdesc='A small python module for wake on lan.'
arch=('any')
url='https://pypi.org/project/wakeonlan/#files'
license=('WTFPL')
makedepends=('python2-setuptools' 'python-setuptools')
source=("https://files.pythonhosted.org/packages/source/${_pkgname::1}/$_pkgname/$_pkgname-$pkgver.tar.gz")
sha512sums=('2a219b0f86f69b4971bc00e49139c53d041fefa1990800289cd72b6897d4d1a8a0fdf9b513594ec61c3c1d0d51f6b31a395a4594d2caba20e5ca823b3c96a855')

prepare() {
  cp -a "$_pkgname-$pkgver"{,-2}
}

build() {
  cd "$_pkgname-$pkgver-2"

  python2 setup.py build

  cd "$srcdir/$_pkgname-$pkgver"

  python setup.py build
}

package_python2-wakeonlan() {
  depends=('python2')

  cd "$_pkgname-$pkgver-2"

  python2 setup.py install --root="$pkgdir" --prefix=/usr -O1 --skip-build

  mv "$pkgdir/usr/bin/$_pkgname" "$pkgdir/usr/bin/${_pkgname}2"
}

package_python-wakeonlan() {
  depends=('python')

  cd "$_pkgname-$pkgver"

  python setup.py install --root="$pkgdir" --prefix=/usr -O1 --skip-build
}

