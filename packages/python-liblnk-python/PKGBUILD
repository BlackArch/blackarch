pkgname=python-liblnk-python
_pkgname=liblnk
__pkgname=liblnk-python
pkgver=20260525
pkgrel=1
pkgdesc='Library and tools to access the Windows Shortcut File (LNK) format.'
url='https://pypi.org/project/liblnk-python/'
arch=('x86_64' 'aarch64')
license=('LGPL3')
depends=('python')
makedepends=('python-setuptools')
source=("https://files.pythonhosted.org/packages/source/${_pkgname::1}/$__pkgname/$__pkgname-$pkgver.tar.gz")
sha512sums=('07dfe937d6bd563d2b3cd82f87352d5e828f556371b7ef932f18d6fe1a9dce5ce621b2e8c5e5c3aff513d2431773ad31a74e099487cd82ebc4fa260dce2ef25f')

build() {
  cd "$_pkgname-$pkgver"

  python setup.py build
}

package() {
  cd "$_pkgname-$pkgver"

  python setup.py install --root="$pkgdir" --prefix=/usr -O1 --skip-build
}

