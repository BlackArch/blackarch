pkgname=pkcrack
pkgver=1.2.3
pkgrel=1
groups=('blackarch' 'blackarch-cracker')
pkgdesc='A PkZip encryption cracker.'
arch=('x86_64' 'aarch64')
url='https://www.unix-ag.uni-kl.de/~conrad/krypto/pkcrack/download1.html'
license=('custom:unknown')
source=("https://www.unix-ag.uni-kl.de/~conrad/krypto/$pkgname/$pkgname-$pkgver.tar.gz")
sha512sums=('b732f898e986308cd7c8b6f3516f19aa05cc10aac072e32746cebe81109aad88324d572357423b295a24aee79318a697c6dd54cbd949c13aa548156b1cc5aec3')

build() {
  cd "$pkgname-$pkgver/src"

  make
}

package() {
  cd "$pkgname-$pkgver"

  _tools="extract findkey makekey pkcrack zipdecrypt"

  install -Dm 644 -t "$pkgdir/usr/share/doc/$pkgname/" doc/*

  cd src

  for i in $_tools ; do
    if [ "$i" != "pkcrack" ]; then
      install -Dm 755 $i "$pkgdir/usr/bin/$pkgname-$i"
    else
      install -Dm 755 $i "$pkgdir/usr/bin/$pkgname"
    fi
  done
}

