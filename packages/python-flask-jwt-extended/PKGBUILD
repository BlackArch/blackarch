pkgname=python-flask-jwt-extended
_pkgname=flask_jwt_extended
pkgver=4.7.4
pkgrel=1
pkgdesc='Extended JSON Web Tokens (JWT) support for Flask.'
arch=('any')
url='https://pypi.org/project/Flask-JWT-Extended/'
license=('MIT')
depends=('python' 'python-black' 'python-cryptography'
         'python-flask' 'python-pallets-sphinx-themes' 'python-pre-commit'
         'python-pyjwt' 'python-sphinx' 'python-tox')
makedepends=('python-build' 'python-installer' 'python-setuptools'
             'python-wheel')
options=(!emptydirs)
source=("https://files.pythonhosted.org/packages/source/${_pkgname::1}/$_pkgname/$_pkgname-$pkgver.tar.gz")
sha512sums=('78db5fa57bc07669c725857337ea8f0b10aed4cbcb3c4fd819813ae33069d8e87b7dd2dfe397769a7a742248bf4cbb4ec555d81f9f350071b553ccedbaeca57a')

build() {
  cd "$_pkgname-$pkgver"

  python -m build --wheel --no-isolation
}

package() {
  cd "$_pkgname-$pkgver"

  python -m installer --destdir="$pkgdir" dist/*.whl
}

