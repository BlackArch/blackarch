pkgname=python-environs
_pkgname=environs
pkgver=15.0.1
pkgrel=1
pkgdesc='Simplified environment variable parsing.'
arch=('any')
url='https://pypi.org/project/environs/#files'
license=('MIT')
depends=('python' 'python-marshmallow' 'python-dotenv')
makedepends=('python-build' 'python-pip')
source=("https://files.pythonhosted.org/packages/source/${_pkgname::1}/$_pkgname/$_pkgname-$pkgver.tar.gz")
sha512sums=('510ff5de019a9656b3d84a674e2096c8e62149671c6e93ada6b61165681a3ed31641dedd9910fe48007352ee43db7c9e6cd01ec52df4259a2f2e95b07d4c9918')

build() {
  cd "$_pkgname-$pkgver"

  python -m build --wheel --outdir="$startdir/dist"
}

package() {
  cd "$_pkgname-$pkgver"

  pip install \
    --verbose \
    --disable-pip-version-check \
    --no-warn-script-location \
    --ignore-installed \
    --no-compile \
    --no-deps \
    --root="$pkgdir" \
    --prefix=/usr \
    --no-index \
    --find-links="file://$startdir/dist" \
    $_pkgname
}

