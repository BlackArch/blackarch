pkgname=python-libfwnt-python
_pkgname=libfwnt
pkgver=20260602
pkgrel=1
pkgdesc='Library for Windows NT data types.'
url='https://pypi.org/project/libfwnt-python/#files'
arch=('x86_64' 'aarch64')
license=('LGPL3')
depends=('python')
makedepends=('python-setuptools')
source=("https://files.pythonhosted.org/packages/source/${_pkgname::1}/$_pkgname/$_pkgname-$pkgver.tar.gz")
sha512sums=('cf4ae9a4bf34c9b7d745958928571b16cc468f00f54434bb1b5d3f588849ced6257cc2e56d302a1e768ba84b334ba4b8fe8d21b3b533a748f4ad5ae6e845e12c')

build() {
  cd "$_pkgname-$pkgver"

  python setup.py build
}

package_python-libfwnt-python() {
  cd "$_pkgname-$pkgver"

  python setup.py install --root="$pkgdir" --prefix=/usr -O1 --skip-build
}

