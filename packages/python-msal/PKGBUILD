pkgname=python-msal
_pkgname=msal
pkgver=1.35.0
pkgrel=1
pkgdesc='Python library that enables your app to access the Microsoft Cloud.'
arch=('any')
url='https://pypi.org/project/msal/#files'
license=('MIT')
depends=('python' 'python-requests' 'python-cryptography' 'python-mock'
         'python-pyjwt')
makedepends=('python-setuptools' 'cmake')
source=("https://files.pythonhosted.org/packages/source/${_pkgname::1}/$_pkgname/$_pkgname-$pkgver.tar.gz")
sha512sums=('293b964ae08db2474811963aed1ca5fec052983e2c65bffecbc1dcc798f5e08fd32d1d569652190fa88d0833cf1557a86d1f41d1fb4127dc0d07993d39e3187b')

build() {
  cd "$_pkgname-$pkgver"

  python setup.py build
}

package() {
  cd "$_pkgname-$pkgver"

  python setup.py install --root="$pkgdir" --prefix=/usr -O1 --skip-build
}

