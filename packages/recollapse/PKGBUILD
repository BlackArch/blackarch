# See COPYING for license details.

pkgname=recollapse
pkgver=1.0.r1.g090d711
pkgrel=1
pkgdesc='Tool for black-box regex fuzzing to bypass validations and discover normalizations in web applications.'
arch=('any')
groups=('blackarch' 'blackarch-fuzzer' 'blackarch-webapp')
url='https://github.com/0xacb/recollapse'
license=('MIT')
depends=('python' 'python-unidecode' 'python-prettytable')
makedepends=('git' 'python-build' 'python-pip')
source=("git+https://github.com/0xacb/$pkgname.git")
sha512sums=('SKIP')

pkgver() {
  cd $pkgname

  ( set -o pipefail
    git describe --long --tags --abbrev=7 2>/dev/null |
      sed 's/^v//;s/\([^-]*-g\)/r\1/;s/-/./g' ||
    printf "%s.%s" "$(git rev-list --count HEAD)" \
      "$(git rev-parse --short=7 HEAD)"
  )
}

build() {
  cd $pkgname

  python -m build --wheel --outdir="$startdir/dist"
}

package() {
  cd $pkgname

  install -Dm 644 -t "$pkgdir/usr/share/doc/$pkgname/" README.md

  cp -a slides/ README.md "$pkgdir/usr/share/doc/$pkgname/"

  pip install \
    --verbose \
    --disable-pip-version-check \
    --no-warn-script-location \
    --ignore-installed \
    --no-compile \
    --no-deps \
    --root="$pkgdir" \
    --prefix=/usr \
    --no-index \
    --find-links="file://$startdir/dist" \
    $pkgname
}

