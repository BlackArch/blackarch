pkgname=trid
pkgver=2.48
pkgrel=1
pkgdesc='An utility designed to identify file types from their binary signatures.'
arch=('any')
groups=('blackarch' 'blackarch-forensic' 'blackarch-binary')
url='http://mark0.net/soft-trid-e.html'
license=('custom:unknown')
depends=('python' 'trid-defs')
source=("https://mark0.net/download/$pkgname.zip")
sha512sums=('ef968dde5261232ad57f885a3ef840331b92f298fc86954067124a7cff1c6346b15e7e566b07cc18595b15013a23e7943626b31270143e5e5a80c98ffb3d751a')

package() {
  install -dm 755 "$pkgdir/usr/bin"

  install -Dm 755 "$pkgname.py" "$pkgdir/usr/share/$pkgname/$pkgname.py"
  install -Dm 644 -t "$pkgdir/usr/share/doc/$pkgname/" readme.txt

  cat > "$pkgdir/usr/bin/$pkgname" << EOF
#!/bin/sh
exec /usr/share/$pkgname/$pkgname.py -d:/usr/share/$pkgname/triddefs.trd "\$@"
EOF

  chmod +x "$pkgdir/usr/bin/$pkgname"
}

