pkgname=python-google-cloud-storage
_pkgname=google_cloud_storage
pkgver=3.12.0
pkgrel=1
pkgdesc='Google Cloud Storage API client library.'
arch=('any')
url='https://pypi.org/project/google-cloud-storage/#files'
license=('Apache-2.0')
depends=('python' 'python-google-cloud-core' 'python-google-resumable-media'
         'python-google-auth' 'python-protobuf' 'python-google-api-core'
         'python-google-resumable-media' 'python-google-crc32c'
         'python-requests')
makedepends=('python-build' 'python-installer' 'python-setuptools'
             'python-wheel')
options=(!emptydirs)
source=("https://files.pythonhosted.org/packages/source/${_pkgname::1}/$_pkgname/$_pkgname-$pkgver.tar.gz")
sha512sums=('aab68bb226e8044a7f11935971bcbe758a7c057590658bcf6c70da9233a36a37a782436c032b3e74428e9bc148ab5728fe12f97bf53ea6d1607e0d13ab30c467')

build() {
  cd "$_pkgname-$pkgver"

  python -m build --wheel --no-isolation
}

package() {
  cd "$_pkgname-$pkgver"

  python -m installer --destdir="$pkgdir" dist/*.whl
}

