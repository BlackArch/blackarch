pkgname=httpgrep
pkgver=4.5
pkgrel=1
groups=('blackarch' 'blackarch-webapp' 'blackarch-scanner')
pkgdesc='Async HTTP(S) scanner that greps response bodies and headers for strings or regex across hosts, ports, CIDR/ranges and TLS-cert vhosts.'
url='https://nullsecurity.net/tools/scanner.html'
license=('custom:unknown')
arch=('any')
depends=('python' 'python-requests')
source=("https://github.com/nullsecuritynet/tools/raw/main/scanner/$pkgname/release/$pkgname-$pkgver.tar.gz")
sha512sums=('af58b1e75c32e029c41ccf9a376423bcbb6ec121123a3a99b230f2bff0209c990c0e54362a9dc0643de29c37cf6ac007a2686a44410ad24ceff1e70561cb9692')

package() {
  cd "$pkgname-$pkgver"

  install -dm 755 "$pkgdir/usr/share/$pkgname"

  install -Dm 755 "$pkgname.py" "$pkgdir/usr/bin/$pkgname"
  install -Dm 644 -t "$pkgdir/usr/share/doc/$pkgname/" README.md
}

