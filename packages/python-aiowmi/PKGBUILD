pkgname=python-aiowmi
_pkgname=${pkgname#python-}
pkgver=1.1.3
pkgrel=1
pkgdesc='Python WMI Queries.'
arch=('any')
# https://github.com/cesbit/aiowmi
url='https://pypi.org/project/aiowmi/#files'
license=('GPL-3.0-or-later')
depends=('python' 'python-pycryptodome' 'python-pyasn1')
makedepends=('python-build' 'python-installer' 'python-setuptools'
             'python-wheel')
source=("https://files.pythonhosted.org/packages/source/${_pkgname::1}/$_pkgname/$_pkgname-$pkgver.tar.gz")
sha512sums=('4cef47f93d3a6fd3a795e7c8fc3ec7c3778b4cb8dbe89309763fc135b264e70e85eb0e72c800c543e5715b4c80785b285ffdd3d62a588b450fe57810cf187858')

build() {
  cd "$_pkgname-$pkgver"

  python -m build --wheel --no-isolation
}

package() {
  cd "$_pkgname-$pkgver"

  python -m installer --destdir="$pkgdir" dist/*.whl

  find "$pkgdir" -type f -iname '*.pyc' -exec rm {} \;
}

