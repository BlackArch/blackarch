pkgname=sysinternals-suite
pkgver=7.1
pkgrel=1
epoch=1
groups=('blackarch' 'blackarch-windows')
pkgdesc='Sysinternals tools suite.'
url='http://sysinternals.com/'
license=('custom:unknown')
arch=('any')
source=('http://download.sysinternals.com/files/SysinternalsSuite.zip')
sha512sums=('ddd0432b749a6a78ae7e7149fa6247644732b965b0f5ad983a8b1bac32d50e7479aab1c95e200822afa43ce74d4ab94bc0487b4112ab7a38152dbffea6d400f4')

package() {
  install -dm 755 "$pkgdir/usr/share/windows/$pkgname"

  find . -type l -exec rm {} \;

  # Transform all files to lowercase
  for f in * ; do
    lc=$(echo $f | tr '[A-Z]' '[a-z]')

    if [ ! -f $f -o -f $lc ]; then
      continue
    fi

    mv -i $f $lc
  done

  install -m 755 *.exe *.sys "$pkgdir/usr/share/windows/$pkgname"
  install -m 644 *.chm *.txt "$pkgdir/usr/share/windows/$pkgname"
}

