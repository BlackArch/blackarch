pkgname=cflow
pkgver=1.8
pkgrel=1
pkgdesc='A C program flow analyzer.'
url='http://www.gnu.org/software/cflow/'
groups=('blackarch' 'blackarch-code-audit')
license=('GPL')
arch=('x86_64' 'aarch64')
source=("http://ftp.gnu.org/gnu/$pkgname/$pkgname-$pkgver.tar.bz2")
sha512sums=('dae9aab42a73af9e1fd61d26a244693ce8f75350179e5c791da4cef1f28d60f2d06127c0fcb67cd207c7811afcece784e446c167e012109b60f83a7839945749')

build() {
  cd "$pkgname-$pkgver"

  ./configure --prefix=/usr

  make
}

package() {
  cd "$pkgname-$pkgver"

  make DESTDIR="$pkgdir" install
}

