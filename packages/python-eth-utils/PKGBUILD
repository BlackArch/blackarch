pkgname=python-eth-utils
_pkgname=eth_utils
pkgver=6.0.0
pkgrel=1
pkgdesc='Common utility functions for ethereum codebases.'
url='https://pypi.org/project/eth-utils/#files'
arch=('any')
license=('MIT')
depends=('python' 'python-eth-hash' 'python-eth-typing' 'python-toolz'
         'python-cytoolz')
makedepends=('python-setuptools')
source=("https://files.pythonhosted.org/packages/source/${_pkgname::1}/$_pkgname/$_pkgname-$pkgver.tar.gz")
sha512sums=('d177edc59e73d9ed247e2ddb3ba221d3f6d8c1e10b867010a5c321b5fda9e33b495b36762b127c9a9dbae38017a31a79c140285b1751734bd87a38d65c4ce6b0')

build() {
  cd "$_pkgname-$pkgver"

  python setup.py build
}

package() {
  cd "$_pkgname-$pkgver"

  python setup.py install --root="$pkgdir" --prefix=/usr -O1 --skip-build
}

