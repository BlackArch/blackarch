pkgname=ipcountry
pkgver=2.3
pkgrel=1
groups=('blackarch' 'blackarch-misc')
pkgdesc='Fetches IPv4 ranges of given country in host and cidr format.'
url='https://nullsecurity.net/tools/misc.html'
license=('custom:unknown')
arch=('any')
depends=('python' 'python-requests')
source=("https://github.com/nullsecuritynet/tools/raw/main/misc/$pkgname/release/$pkgname-$pkgver.tar.gz")
sha512sums=('bdc81d3bcf529f00c1bab83349e356b9f0f1673b1e6c3ee2bb2d67ac8293d6699c7ef0ff79540217710572f8c5ab1da906e484443e28491c4902869a92e052d9')

package() {
  cd "$pkgname-$pkgver"

  install -dm 755 "$pkgdir/usr/share/$pkgname"

  install -Dm 755 "$pkgname.py" "$pkgdir/usr/bin/$pkgname"
  install -Dm 644 -t "$pkgdir/usr/share/doc/$pkgname/" README.md
}

