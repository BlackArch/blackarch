pkgname=python-libolecf-python
_pkgname=libolecf
pkgver=20260526
pkgrel=1
pkgdesc='Library and tools to access the OLE 2 Compound File (OLECF) format.'
url='https://pypi.org/project/libolecf-python/#files'
arch=('x86_64' 'aarch64')
license=('LGPL3')
depends=('python')
makedepends=('python-setuptools')
source=("https://files.pythonhosted.org/packages/source/${_pkgname::1}/$_pkgname/$_pkgname-python-$pkgver.tar.gz")
sha512sums=('b4147006da29c17bdf405c3dbd26287f358a63ac08a3c7a428b22ed70c96afbeb4007a27bf49ee530bf19db28d0469fe8fbdaad4cf3609d616133d84a19988ed')

build() {
  cd "$_pkgname-$pkgver"

  python setup.py build
}

package() {
  cd "$_pkgname-$pkgver"

  python setup.py install --root="$pkgdir" --prefix=/usr -O1 --skip-build
}

