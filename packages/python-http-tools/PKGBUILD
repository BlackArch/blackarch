pkgname=python-http-tools
_pkgname=http-tools
pkgver=6.0.1
pkgrel=1
pkgdesc='httptools helps you to capture, repeat and live intercept HTTP requests. It is built on top of [mitmproxy].'
arch=('any')
url='https://pypi.org/project/http-tools/#files'
license=('GPL3')
depends=('python' 'mitmproxy')
makedepends=('python-setuptools')
source=("https://files.pythonhosted.org/packages/source/${_pkgname::1}/$_pkgname/$_pkgname-$pkgver.tar.gz")
sha512sums=('3840f2c9e880391b3ec1ea563078eb3467fab922705c422bd3b2d3b8ede63760f591d2faa3f8dfa7f68566fb37f065388190067d7c34d5e22f50bb87217d8103')

prepare() {
  cd "$_pkgname-$pkgver"

  sed -i 's/>=6.0.1<=6.0.2//' setup.py
}

build() {
  cd "$_pkgname-$pkgver"

  python setup.py build
}

package() {
  cd "$_pkgname-$pkgver"

  python setup.py install --prefix=/usr --root="$pkgdir" -O1 --skip-build
}

