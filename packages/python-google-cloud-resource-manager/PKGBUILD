pkgname=python-google-cloud-resource-manager
_pkgname=google-cloud-resource-manager
pkgver=1.17.0
_pyver=3.14
pkgrel=1
pkgdesc='Google Cloud Resource Manager API client library.'
arch=('any')
url='https://pypi.org/project/google-cloud-resource-manager/#files'
license=('Apache')
depends=('python' 'python-google-cloud-core')
makedepends=('python-setuptools')
source=("https://files.pythonhosted.org/packages/source/${_pkgname::1}/$_pkgname/$_pkgname-$pkgver.tar.gz")
sha512sums=('1f58ae158f1fe95ebc9057842b2d9e0d246fbb7197229334eef6f62ded0bf86392eaf61cb26bce9df44c5c8cfcf54dc44c4cb697f8ed05eb076d21ee87d7468d')

build() {
  cd "$_pkgname-$pkgver"

  python setup.py build
}

package() {
  cd "$_pkgname-$pkgver"

  python setup.py install --root="$pkgdir" --prefix=/usr -O1 --skip-build

  rm -rf "$pkgdir/usr/lib/python$_pyver/site-packages/tests/"
}

