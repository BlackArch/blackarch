pkgname=pe-bear
_pkgname=PE-bear
pkgver=0.7.2
pkgrel=1
pkgdesc='A freeware reversing tool for PE files.'
url='https://github.com/hasherezade/pe-bear'
groups=('blackarch' 'blackarch-windows' 'blackarch-malware' 'blackarch-binary'
        'blackarch-reversing' 'blackarch-disassembler')
license=('custom:unknown')
arch=('any')
source=("https://github.com/hasherezade/pe-bear/releases/download/v$pkgver/${_pkgname}_${pkgver}_qt6_x64_win_vs22.zip")
sha512sums=('9389466e2bcda7f19d8a79c65de36bc4db279e231082face20cf89feeb5dc98e7bd51aef0c19a9a9d470a933ef35773bc8bfe31c3b74a83178e8f7a6c8c79730')

package() {
  install -dm 755 "$pkgdir/usr/share/windows/$pkgname"

  rm -f "${_pkgname}_${pkgver}_x64_win_vs17.zip" \
    "styles/${_pkgname}_${pkgver}_x64_win_vs17.zip"

  cp -a * "$pkgdir/usr/share/windows/$pkgname/"
}

