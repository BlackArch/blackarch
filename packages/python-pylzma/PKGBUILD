pkgbase=python-pylzma
pkgname=('python2-pylzma' 'python-pylzma')
_pkgname=pylzma
pkgver=0.6.1
pkgrel=1
pkgdesc='Python bindings for the LZMA library.'
arch=('x86_64' 'aarch64')
url='https://pypi.org/project/pylzma/#files'
license=('LGPL-2.1-only')
makedepends=('python2-setuptools' 'python-setuptools')
source=("https://files.pythonhosted.org/packages/source/${_pkgname::1}/$_pkgname/$_pkgname-$pkgver.tar.gz"
        "PyTypeObject.patch")
sha512sums=('b3fab5742d09c97b068c4bf5606c2285c93778e290f6aafdb784c35eb6f11652be49aa85f708264e8aa443662e07fa93f76ecb204e0137425f64e7145e4df793')
            'dcdae0215d54cee4906e1b0619da83e39ebdd9f276d46f2f5573ac400b83deb8dc91dbc5a60d160c3ee0705703148d79a3bc7b2fd9b9c0e3b0432708f3a201cb')

prepare() {
  patch -d "$_pkgname-$pkgver" -p1 < PyTypeObject.patch
  cp -a "$_pkgname-$pkgver"{,-2}
}

build() {
  cd "$_pkgname-$pkgver-2"

  python2 setup.py build

  cd "$srcdir/$_pkgname-$pkgver"

  python setup.py build
}

package_python2-pylzma() {
  depends=('python2')

  cd "$_pkgname-$pkgver-2"

  python2 setup.py install --root="$pkgdir" --prefix=/usr -O1 --skip-build
}

package_python-pylzma() {
  depends=('python')

  cd "$_pkgname-$pkgver"

  python setup.py install --root="$pkgdir" --prefix=/usr -O1 --skip-build
}

