pkgname=python-xdis
_pkgname=xdis
pkgver=6.3.0
_pyver=3.14
pkgrel=1
pkgdesc='Python cross-version byte-code disassembler and marshal routines.'
url='https://pypi.org/project/xdis/#files'
arch=('any')
license=('GPL2')
depends=('python')
makedepends=('python-setuptools' 'python-pip' 'python-wheel')
source=("https://files.pythonhosted.org/packages/source/${_pkgname::1}/$_pkgname/$_pkgname-$pkgver.tar.gz")
sha512sums=('5453e483d9e8f90cc9b21e79aa086ba7b6a5179fd6c9ba44054da78e03dfa845493336a9523a104823724f7010f9fa8bdf468bb227b7b5c726ba3e6232690aad')

build() {
  cd "$_pkgname-$pkgver"

  python setup.py build
}

package() {
  cd "$_pkgname-$pkgver"

  python setup.py install --prefix=/usr --root="$pkgdir" -O1 --skip-build
}

