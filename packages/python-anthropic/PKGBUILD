pkgname=python-anthropic
_pkgname=${pkgname#python-}
pkgver=0.84.0
pkgrel=1
pkgdesc='The official Python library for the anthropic API.'
arch=('any')
url='https://pypi.org/project/anthropic/#files'
license=('MIT')
depends=('python' 'python-anyio' 'python-distro' 'python-httpx' 'python-jiter'
         'python-pydantic' 'python-pydantic-core' 'python-sniffio'
         'python-tokenizers' 'python-typing_extensions'
         'python-docstring-parser' 'python-inline-snapshot')
makedepends=('python-build' 'python-installer' 'python-setuptools'
             'python-wheel' 'python-hatchling' 'python-hatch-fancy-pypi-readme')
options=(!emptydirs)
source=("https://files.pythonhosted.org/packages/source/${_pkgname::1}/$_pkgname/$_pkgname-$pkgver.tar.gz")
sha512sums=('845c7ca4140f8ca1ffebf83ecfab8bacde7a61594a5ad9e75ed53fe6367be0ccef95d869226fd41e8efc034af049facd4634e0d752bdb41a1a22ef05d1da4dc5')

prepare() {
  cd "$_pkgname-$pkgver"

  sed -i 's|hatchling==|hatchling>=|' pyproject.toml
  sed -i '/^filterwarnings = \[/,/^]/d' pyproject.toml
}

build() {
  cd "$_pkgname-$pkgver"

  python -m build --wheel --no-isolation
}

package() {
  cd "$_pkgname-$pkgver"

  python -m installer --destdir="$pkgdir" dist/*.whl
}

