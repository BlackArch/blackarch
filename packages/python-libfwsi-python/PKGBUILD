pkgname=python-libfwsi-python
_pkgname=libfwsi
pkgver=20260522
pkgrel=1
pkgdesc='Python bindings module for libfwsi.'
url='https://pypi.org/project/libfwsi-python/#files'
arch=('x86_64' 'aarch64')
license=('LGPL3')
depends=('python')
makedepends=('python2-setuptools' 'python-setuptools')
source=("https://files.pythonhosted.org/packages/source/${_pkgname::1}/$_pkgname/$_pkgname-python-$pkgver.tar.gz")
sha512sums=('995c7ca9863c5a950d3a0d220b8db9dec2408459e86b09c7cd730d3f79e843f1a9f92398f520dd6104de2b1175cfc168cdf2681624446c0e933fc2728dcce14b')

build() {
  cd "$_pkgname-$pkgver"

  python setup.py build
}

package() {
  cd "$_pkgname-$pkgver"

  python setup.py install --root="$pkgdir" --prefix=/usr -O1 --skip-build
}

