pkgname=python-google-cloud-container
_pkgname=google-cloud-container
pkgver=2.65.0
pkgrel=1
pkgdesc='Google Container Engine API client library.'
arch=('any')
url='https://pypi.org/project/google-cloud-container/#files'
license=('Apache')
depends=('python' 'python-google-api-core')
makedepends=('python-setuptools')
source=("https://files.pythonhosted.org/packages/source/${_pkgname::1}/$_pkgname/$_pkgname-$pkgver.tar.gz")
sha512sums=('2c804e5f5659447741892a9f47f10e23adb2b5227c7ae5a7eaece135fe5af7e47651a24fcd642cc737eccc372d3ac9583b31b9028587eb2921cc97348cf8180b')

build() {
  cd "$_pkgname-$pkgver"

  python setup.py build
}

package() {
  cd "$_pkgname-$pkgver"

  python setup.py install --prefix=/usr --root="$pkgdir" --optimize=1 \
    --skip-build
}

