pkgname=python-google-cloud-monitoring
_pkgname=google-cloud-monitoring
pkgver=2.31.0
pkgrel=1
pkgdesc='Stackdriver Monitoring API client library.'
arch=('any')
url='https://pypi.org/project/google-cloud-monitoring/#files'
license=('Apache')
depends=('python' 'python-google-api-core')
makedepends=('python-setuptools')
source=("https://files.pythonhosted.org/packages/source/${_pkgname::1}/$_pkgname/$_pkgname-$pkgver.tar.gz")
sha512sums=('921bcd7303be9e2a68b385f29ed6524c159e9ce5d6b38e56d0e62f5497b0398f34d13f3247b707506ef4e1ed3c24d9365dadbef379361f66f8a50a88e493e32b')

build() {
  cd "$_pkgname-$pkgver"

  python setup.py build
}

package() {
  cd "$_pkgname-$pkgver"

  python setup.py install --prefix=/usr --root="$pkgdir" --optimize=1 \
    --skip-build
}

