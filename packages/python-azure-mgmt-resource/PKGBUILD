pkgname=python-azure-mgmt-resource
_pkgname=azure-mgmt-resource
pkgver=25.0.0
pkgrel=1
pkgdesc='Microsoft Azure Resource Management Client Library for Python.'
arch=('any')
url='https://pypi.org/project/azure-mgmt-resource/#files'
license=('MIT')
depends=('python')
makedepends=('python-setuptools')
source=("https://files.pythonhosted.org/packages/source/${_pkgname::1}/$_pkgname/$_pkgname-$pkgver.zip")
sha512sums=('433b9938f7e1553d08d0e1b78e568610f30a9b77a83dbf4a1157475d69e31ed7a1fe19a69b43842f0e13547f5fe89d072e57cc6ffae86c78ad3deb6fbf19bd92')

build() {
  cd "$_pkgname-$pkgver"

  python setup.py build
}

package() {
  cd "$_pkgname-$pkgver"

  python setup.py install --prefix=/usr --root="$pkgdir" --optimize=1 \
    --skip-build
}

