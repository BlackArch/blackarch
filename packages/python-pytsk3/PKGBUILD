pkgname=python-pytsk3
_pkgname=pytsk3
pkgver=20260520
pkgrel=1
pkgdesc='Python bindings for the sleuthkit.'
arch=('x86_64' 'aarch64')
url='https://pypi.org/project/pytsk3/#files'
license=('Apache')
depends=('python')
makedepends=('python-setuptools')
source=("https://files.pythonhosted.org/packages/source/${_pkgname::1}/$_pkgname/$_pkgname-$pkgver.tar.gz")
sha512sums=('3ee998a7dc69d5d7feb62a3d0d406fb14dceb0fcdf9762afc433913cfac718f6ec44082ecd98b6c7fa7a4610eeee4842af231ecd987f062716733b46c8556b0e')

build() {
  cd "$_pkgname-$pkgver"

  python setup.py build
}

package() {
  cd "$_pkgname-$pkgver"

  python setup.py install --root="$pkgdir" --prefix=/usr -O1 --skip-build
}

