pkgname=python-dfvfs
_pkgname=dfvfs
pkgver=20260411
pkgrel=1
pkgdesc='Python module that provides read-only access to file-system objects from various storage media types and file formats.'
arch=('any')
url='https://pypi.org/project/dfvfs/'
license=('Apache')
depends=('python')
makedepends=('python-setuptools')
source=("https://files.pythonhosted.org/packages/source/${_pkgname::1}/$_pkgname/$_pkgname-$pkgver.tar.gz")
sha512sums=('5489a664d3616165f6b16ee187d86a78daa9523835524b8ddf993b798c8893a9c96f6d720fd8cc96ccfdd11354c40533bf8aa3ed11a7b39985d38c8c4943c53d')

build() {
  cd "$_pkgname-$pkgver"

  python setup.py build
}

package() {
  cd "$_pkgname-$pkgver"

  python setup.py install --root="$pkgdir" --prefix=/usr -O1 --skip-build
}

