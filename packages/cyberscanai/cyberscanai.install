post_install() {
  set -e
  cd /usr/share/cyberscanai
  python -m venv venv
  source venv/bin/activate &&
  pip install --isolated --root=/usr/share/cyberscanai --prefix=venv \
      fastmcp scapy
}

post_upgrade() {
  set -e
  cd /usr/share/cyberscanai
  source venv/bin/activate &&
  pip install --isolated --root=/usr/share/cyberscanai --prefix=venv \
      fastmcp scapy -U
  
}

post_remove() {
  rm -rf /usr/share/cyberscanai
}
