post_install() {
  set -e
  cd /usr/share/cyberscanai
  python -m venv venv
  source venv/bin/activate &&
  pip install --isolated --root=/usr/share/cyberscanai --prefix=venv \
      cyberscanai
}

post_upgrade() {
  set -e
  cd /usr/share/cyberscanai
  source venv/bin/activate &&
  pip install --isolated --root=/usr/share/cyberscanai --prefix=venv \
      cyberscanai -U
  
}

post_remove() {
  rm -rf /usr/share/cyberscanai
}
