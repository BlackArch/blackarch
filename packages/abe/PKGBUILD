# See COPYING for license details.

pkgname=abe
pkgver=20251027
pkgrel=1
pkgdesc='Android backup extractor'
arch=('any')
groups=('blackarch')
url='https://github.com/nelenkov/android-backup-extractor'
license=('Apache-2.0')
depends=('java-environment')
makedepends=()
source=("https://github.com/nelenkov/android-backup-extractor/releases/download/latest/abe-540a57d.jar")
sha512sums=('8f04f0a14f4cf5f5e83b3973587fc7976bc3f9c97e85779d590d561a81d44550e5f2b343c88e76120c3ac7c0e5ffb12a0e7a7afaf89a92d8447240e60fad3e3e')

package() {
  install -dm 755 "$pkgdir/usr/bin"

  install -Dm 755 "abe-540a57d.jar" \
    "$pkgdir/usr/share/$pkgname/$pkgname-$pkgver.jar"

  cat > "$pkgdir/usr/bin/$pkgname" << EOF
#!/bin/sh
exec java -jar /usr/share/$pkgname/$pkgname-$pkgver.jar "\$@"
EOF

  chmod +x "$pkgdir/usr/bin/$pkgname"
}