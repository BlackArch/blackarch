pkgname=python-ppdeep
_pkgname=ppdeep
pkgver=20260221
pkgrel=1
pkgdesc='Pure-Python library for computing fuzzy hashes (ssdeep).'
arch=('any')
url='https://pypi.org/project/ppdeep/#files'
license=('Apache')
depends=('python')
makedepends=('python-setuptools' 'python-pip' 'python-wheel')
source=("https://files.pythonhosted.org/packages/source/${_pkgname::1}/$_pkgname/$_pkgname-$pkgver.tar.gz")
sha512sums=('24b5f1d1be967a14755a72fa54968a2e4a5bacf8226ec522b46f444a19f3ad243895570b427bb018c590a487d314293c80574fd32fc2063b039f39800ba33358')

build() {
  cd "$_pkgname-$pkgver"

  python setup.py build
}

package() {
  cd "$_pkgname-$pkgver"

  python setup.py install --root="$pkgdir" --prefix=/usr -O1 --skip-build
}

