pkgname=python-google-cloud-iam
_pkgname=google-cloud-iam
pkgver=2.23.0
pkgrel=1
pkgdesc='IAM Service Account Credentials API client library.'
arch=('any')
url='https://pypi.org/project/google-cloud-iam/#files'
license=('Apache')
depends=('python')
makedepends=('python-setuptools')
source=("https://files.pythonhosted.org/packages/source/${_pkgname::1}/$_pkgname/$_pkgname-$pkgver.tar.gz")
sha512sums=('4cf8932bde6fd578f9d4e27cca6e5ff0d6dcfc2185d80c7c64a11323fd79ada22fa48882a3d8d2761c10c8ece32e1930f1295b4dae8f086734e06393a1c0bf3b')

build() {
  cd "$_pkgname-$pkgver"

  python setup.py build
}

package() {
  cd "$_pkgname-$pkgver"

  python setup.py install --prefix=/usr --root="$pkgdir" --optimize=1 \
    --skip-build
}

