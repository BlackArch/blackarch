pkgname=python-libcreg-python
_pkgname=libcreg-python
pkgver=20260523
pkgrel=1
pkgdesc='Python bindings module for libcreg.'
url='https://pypi.org/project/libcreg-python/'
arch=('x86_64' 'aarch64')
license=('LGPL3')
depends=('python')
makedepends=('python-setuptools')
source=("https://files.pythonhosted.org/packages/source/${_pkgname::1}/$_pkgname/$_pkgname-$pkgver.tar.gz")
sha512sums=('51e4782a023c5fc363c549e372a643097a8e34d9d1aea3d30ee24675c24cf35b1ce9cb76939595006984589885b9fe0e4a639c90a2749cde3839906913a70d79')

build() {
  cd "libcreg-$pkgver"

  python setup.py build
}

package() {
  cd "libcreg-$pkgver"

  python setup.py install --root="$pkgdir" --prefix=/usr -O1 --skip-build
}

