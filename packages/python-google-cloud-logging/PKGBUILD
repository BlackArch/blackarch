pkgname=python-google-cloud-logging
_pkgname=google-cloud-logging
pkgver=3.16.0
pkgrel=1
pkgdesc='Stackdriver Logging API client library.'
arch=('any')
url='https://pypi.org/project/google-cloud-logging/#files'
license=('Apache')
depends=('python' 'python-google-api-core' 'python-google-cloud-core')
makedepends=('python-setuptools')
source=("https://files.pythonhosted.org/packages/source/${_pkgname::1}/$_pkgname/$_pkgname-$pkgver.tar.gz")
sha512sums=('1d3f55a5989d73c9770f7267b41d0f4cc6ea650c0857757aa7d8fed99efac88bf4ea8537edaa1bfa974eda85fba7a01d35ee42d7752bbd9477de52495efabb85')

build() {
  cd "$_pkgname-$pkgver"

  python setup.py build
}

package() {
  cd "$_pkgname-$pkgver"

  python setup.py install --prefix=/usr --root="$pkgdir" --optimize=1 \
    --skip-build
}

