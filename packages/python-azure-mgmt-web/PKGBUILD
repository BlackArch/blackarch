pkgname=python-azure-mgmt-web
_pkgname=azure-mgmt-web
pkgver=11.0.0
pkgrel=1
pkgdesc='Microsoft Azure Web Apps Management Client Library for Python.'
arch=('any')
url='https://pypi.org/project/azure-mgmt-web/#files'
license=('MIT')
depends=('python')
makedepends=('python-setuptools')
source=("https://files.pythonhosted.org/packages/source/${_pkgname::1}/$_pkgname/$_pkgname-$pkgver.zip")
sha512sums=('bd5b8bf599a35b32ba957a1c83987075aa83bc8cd54625345718d07cdd8bba7788a8aeda7f6a1c337c935f124e5aa5a4b852ab443dd107d79bc1674058abb80e')

build() {
  cd "$_pkgname-$pkgver"

  python setup.py build
}

package() {
  cd "$_pkgname-$pkgver"

  python setup.py install --prefix=/usr --root="$pkgdir" --optimize=1 \
    --skip-build
}

