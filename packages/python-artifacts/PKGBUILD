pkgname=python-artifacts
_pkgname=artifacts
pkgver=20260421
pkgrel=1
pkgdesc='Digital Forensics Artifact Repository.'
url='https://pypi.org/project/artifacts/#files'
arch=('any')
license=('Apache')
depends=('python' 'python-yaml' 'python-pyaml' 'python-mock' 'python-pbr'
         'python-six')
makedepends=('python-setuptools')
source=("https://files.pythonhosted.org/packages/source/${_pkgname::1}/$_pkgname/$_pkgname-$pkgver.tar.gz")
sha512sums=('a1d960eedf004785c05d7ea5a60c6d5bc66629541adf3db8eef2ba29d5a58e65ce352ffb1ed1cf66ef8d33bfae196be8c3fb8844f71b8edd847fe972560f5b46')

build() {
  cd "$_pkgname-$pkgver"

  python setup.py build
}

package() {
  cd "$_pkgname-$pkgver"

  python setup.py install --root="$pkgdir" --prefix=/usr -O1 --skip-build
}

