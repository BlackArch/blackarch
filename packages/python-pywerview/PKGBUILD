pkgname=python-pywerview
_pkgname=pywerview
pkgver=0.7.6
pkgrel=1
pkgdesc="A Python port of PowerSploit's PowerView'."
arch=('any')
url='https://pypi.org/project/pywerview/#files'
license=('GPL3')
depends=('python' 'python-pyasn1' 'python-gssapi'
         'python-ldap3' 'python-beautifulsoup4' 'impacket' 'python-lxml' )
makedepends=('python-setuptools')
source=("https://files.pythonhosted.org/packages/source/${_pkgname::1}/$_pkgname/$_pkgname-$pkgver.tar.gz")
sha512sums=('b3a5a96855a18fe8e2bd62b0b1f548029dfe55b801be469437ff27f3629e3984b5557656cfe234557b28d052a88dc9b60e8d2ee12ec1fb6269e5cef0fb2411d2')

build() {
  cd "$_pkgname-$pkgver"

  python setup.py build
}

package() {
  cd "$_pkgname-$pkgver"

  python setup.py install --root="$pkgdir" --prefix=/usr -O1 --skip-build
}

