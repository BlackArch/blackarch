pkgname=python-paramiko-ng
_pkgname=${pkgname#python-}
pkgver=2.9.0
pkgrel=1
pkgdesc='SSHv2 protocol library for Python (actively maintained fork of paramiko).'
arch=('any')
url='https://github.com/ploxiln/paramiko-ng'
license=('LGPL')
depends=('python' 'python-bcrypt' 'python-cryptography' 'python-pynacl')
makedepends=('python-build' 'python-installer' 'python-setuptools'
             'python-wheel')
provides=('python-paramiko')
conflicts=('python-paramiko')
options=(!emptydirs)
source=("https://files.pythonhosted.org/packages/source/${_pkgname::1}/$_pkgname/paramiko_ng-$pkgver.tar.gz")
sha512sums=('baca089dece30a7d5b75c1e20ffa0729181e178b0dd0f9a8954e381087f5eb1b7059790403a226bd9909ab246c208a3ca66949e42c02d7496bae1fbc3f917d53')

build() {
  cd "paramiko_ng-$pkgver"

  python -m build --wheel --no-isolation
}

package() {
  cd "paramiko_ng-$pkgver"

  python -m installer --destdir="$pkgdir" dist/*.whl
}
