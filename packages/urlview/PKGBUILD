pkgname="urlview"
_pkgsrcdir="urlview-ng-1e"
pkgver=1e
pkgrel=1
pkgdesc='A curses URL parser for text files.'
arch=('x86_64' 'aarch64')
groups=('blackarch' 'blackarch-misc')
url="http://packages.qa.debian.org/u/urlview.html"
license=('0BSD' 'GPL-2.0-or-later')
depends=('bash' 'glibc' 'ncurses')
makedepends=('git')
options=('!debug')
source=("https://ftp.debian.org/debian/pool/main/u/urlview/${pkgname}_${pkgver}.orig.tar.gz")
sha512sums=('c55f99f43708b664a52cce41814dbc8482b98e3d18c78fdd4cf542860ec730b0c7c91c3e44b7e1bcd21e89c9aca2566dba3da7321e462e6b7cd1fd22d1fa1b2b')

build() {
  cd "$_pkgsrcdir"
  
  make
}

package() {
  cd "$_pkgsrcdir"
  
  DESTDIR="$pkgdir" PREFIX='/usr' make install

  install -Dm644 'LICENSES/0BSD.txt' "$pkgdir/usr/share/licenses/$pkgname/LICENSE.0BSD"
}
