pkgname=python-rq
_pkgname=${pkgname#python-}
pkgver=2.7.0
pkgrel=1
pkgdesc='A simple, lightweight, library for creating background jobs, and processing them.'
arch=('any')
url='https://pypi.org/project/rq/#files'
license=('BSD')
depends=('python' 'python-click' 'python-redis')
makedepends=('python-build' 'python-pip')
options=(!emptydirs)
source=("https://files.pythonhosted.org/packages/source/${_pkgname::1}/$_pkgname/$_pkgname-$pkgver.tar.gz")
sha512sums=('323a7b9f9d8ee2a74434d647db131c20d975f93215993c0410574f075fc5f6f340ebb4480c8acf8102944c13c0e699309baaf1a2b9a9f6a71367e0c772896ecb')

build() {
  cd "$_pkgname-$pkgver"

  python -m build --wheel --outdir="$startdir/dist"
}

package() {
  cd "$_pkgname-$pkgver"

  pip install \
    --verbose \
    --disable-pip-version-check \
    --no-warn-script-location \
    --ignore-installed \
    --no-compile \
    --no-deps \
    --root="$pkgdir" \
    --prefix=/usr \
    --no-index \
    --find-links="file://$startdir/dist" \
    $_pkgname
}

