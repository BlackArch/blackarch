pkgname=python-splunk-sdk
_pkgname=splunk-sdk
pkgver=3.0.0
pkgrel=1
pkgdesc='The Splunk Software Development Kit for Python.'
arch=('any')
url='https://pypi.org/project/splunk-sdk/#files'
depends=('python' 'python-deprecation')
makedepends=('python-setuptools')
license=('Apache')
options=(!emptydirs)
source=("https://files.pythonhosted.org/packages/source/${_pkgname::1}/$_pkgname/$_pkgname-$pkgver.tar.gz")
sha512sums=('26ff93c8f2809f2529109120b4b844339ebe6cdec06aae45f6e2b84ff53f860ce2b8a4b4fb4d42e8a5dc422892f8c9f3550d9acb67f4f4b1e2c57a1a3785cea5')

build() {
  cd "$_pkgname-$pkgver"

  python setup.py build
}

package() {
  cd "$_pkgname-$pkgver"

  python setup.py install --root="$pkgdir" --prefix=/usr -O1 --skip-build
}

